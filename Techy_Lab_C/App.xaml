<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Techy_Lab_C"
             x:Class="Techy_Lab_C.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="PageBackground">#1A1A2E</Color>
            <Color x:Key="QuestionBarBackground">#CC000000</Color>
            <Color x:Key="PrimaryText">#FFFFFF</Color>
            <Color x:Key="SecondaryText">#A8B2D8</Color>
            <Color x:Key="TrueColor">#00B4D8</Color>
            <Color x:Key="FalseColor">#E63946</Color>
            <Color x:Key="OverlayTrue">#8000B4D8</Color>
            <Color x:Key="OverlayFalse">#80E63946</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
